pipeline {
    agent any

    tools {
        jdk 'jdk21'
        maven 'maven3'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages {

        stage('Git Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'git-cred',
                    url: 'https://github.com/hanamanttaranal-cpu/java-production-level.git'
            }
        }

        stage('Compile') {
            steps {
                dir('backend') {
                sh 'mvn compile'
            }
        }
        }
        

        stage('Test') {
            steps {
                dir('backend') {
                sh 'mvn test'
            }
        }
        }

        stage('Trivy Scan') {
            steps {
                sh 'trivy fs --format table -o fs.html .'
            }
        }

       stage('SonarQube Analysis') {
            steps {
                dir('backend') {
                    withSonarQubeEnv('sonar-server') {
                        // Use triple DOUBLE quotes here to find SCANNER_HOME
                        sh """
                        ${SCANNER_HOME}/bin/sonar-scanner \
                        -Dsonar.projectName=ecommerce-backend \
                        -Dsonar.projectKey=ecommerce-backend \
                        -Dsonar.sources=. \
                        -Dsonar.java.binaries=target
                        """
                    }
                }
            }
        }

        stage('Build') {
            steps {
                dir('backend') { // Added missing dir wrapper
                    sh 'mvn package -DskipTests' 
                }
            }
        }

        stage('Publish Artifacts') {
            steps {
                dir('backend') {
                withMaven(
                    globalMavenSettingsConfig: 'maven-settings',
                    jdk: 'jdk21',
                    maven: 'maven3',
                    traceability: true
                ) {
                    sh 'mvn deploy'
                }
            }
        }
        }

        stage('Trivy FS Scan') {
            steps {
                dir('backend') {
                    sh 'trivy fs --format table -o fs-report.html .'
                }
            }
        }

        stage('Docker Build (Compose)') {
            steps {
                sh 'docker compose build'
            }
        }
        stage('push image dockeub') {
            steps {
                // This step should not normally be used in your script. Consult the inline help for details.
            withDockerRegistry(credentialsId: 'docker-reg') {
                sh 'docker push sureshb2/ecommerce-app:latest'
    // some block
             }
            }
        }
    
    }
}
